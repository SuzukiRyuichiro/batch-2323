   "source": [
    "name = 'Alex%'\n",
    "\n",
    "with connect('data/soccer.sqlite') as conn:\n",
    "    players = pd.read_sql(\n",
    "        \"SELECT * FROM Player WHERE player_name LIKE ? AND\", con=conn, params=[name]\n",
    "    )\n",
    "\n",
    "players"
   ]
